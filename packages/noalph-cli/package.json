{
  "name": "@alphaisyour/cli",
  "version": "0.3.0",
  "description": "CLI resmi noalphjs — noalph dev, build, preview",
  "type": "module",
  "bin": {
    "noalph": "./dist/bin/noalph.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@alphaisyour/shared": "workspace:*",
    "picocolors": "^1.0.0",
    "vite": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "*",
    "vitest": "*"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
